        "# Practical 7: Text Preprocessing and TF-IDF using Python\n",
        "\n",
        "# Import Libraries\n",
        "import nltk\n",
        "import pandas as pd\n",
        "\n",
        "# Download Required NLTK Packages\n",
        "nltk.download('punkt')\n",
        "nltk.download('stopwords')\n",
        "nltk.download('wordnet')\n",
        "nltk.download('averaged_perceptron_tagger')\n",
        "\n",
        "# NLP Libraries\n",
        "from nltk.tokenize import word_tokenize\n",
        "from nltk.corpus import stopwords\n",
        "from nltk.stem import PorterStemmer\n",
        "from nltk.stem import WordNetLemmatizer\n",
        "from nltk import pos_tag\n",
        "\n",
        "# TF-IDF\n",
        "from sklearn.feature_extraction.text import TfidfVectorizer\n",
        "\n",
        "# -----------------------------------------\n",
        "# Step 1: Sample Documents\n",
        "# -----------------------------------------\n",
        "\n",
        "documents = [\n",
        "    \"Data Science is an important field of study.\",\n",
        "    \"Machine Learning is used in Data Science.\",\n",
        "    \"Python is widely used for Artificial Intelligence and Data Analysis.\"\n",
        "]\n",
        "\n",
        "print(\"Original Documents:\\n\")\n",
        "\n",
        "for doc in documents:\n",
        "    print(doc)\n",
        "\n",
        "# -----------------------------------------\n",
        "# Step 2: Tokenization\n",
        "# -----------------------------------------\n",
        "\n",
        "print(\"\\nTokenization:\\n\")\n",
        "\n",
        "tokenized_docs = []\n",
        "\n",
        "for doc in documents:\n",
        "    tokens = word_tokenize(doc)\n",
        "    tokenized_docs.append(tokens)\n",
        "    print(tokens)\n",
        "\n",
        "# -----------------------------------------\n",
        "# Step 3: POS Tagging\n",
        "# -----------------------------------------\n",
        "\n",
        "print(\"\\nPOS Tagging:\\n\")\n",
        "\n",
        "for tokens in tokenized_docs:\n",
        "    tagged = pos_tag(tokens)\n",
        "    print(tagged)\n",
        "\n",
        "# -----------------------------------------\n",
        "# Step 4: Stopword Removal\n",
        "# -----------------------------------------\n",
        "\n",
        "stop_words = set(stopwords.words('english'))\n",
        "\n",
        "cleaned_docs = []\n",
        "\n",
        "print(\"\\nAfter Stopword Removal:\\n\")\n",
        "\n",
        "for tokens in tokenized_docs:\n",
        "\n",
        "    filtered = [\n",
        "        word for word in tokens\n",
        "        if word.lower() not in stop_words\n",
        "    ]\n",
        "\n",
        "    cleaned_docs.append(filtered)\n",
        "\n",
        "    print(filtered)\n",
        "\n",
        "# -----------------------------------------\n",
        "# Step 5: Stemming\n",
        "# -----------------------------------------\n",
        "\n",
        "stemmer = PorterStemmer()\n",
        "\n",
        "print(\"\\nStemming:\\n\")\n",
        "\n",
        "stemmed_docs = []\n",
        "\n",
        "for tokens in cleaned_docs:\n",
        "\n",
        "    stemmed = [stemmer.stem(word) for word in tokens]\n",
        "\n",
        "    stemmed_docs.append(stemmed)\n",
        "\n",
        "    print(stemmed)\n",
        "\n",
        "# -----------------------------------------\n",
        "# Step 6: Lemmatization\n",
        "# -----------------------------------------\n",
        "\n",
        "lemmatizer = WordNetLemmatizer()\n",
        "\n",
        "print(\"\\nLemmatization:\\n\")\n",
        "\n",
        "lemmatized_docs = []\n",
        "\n",
        "for tokens in cleaned_docs:\n",
        "\n",
        "    lemmatized = [\n",
        "        lemmatizer.lemmatize(word)\n",
        "        for word in tokens\n",
        "    ]\n",
        "\n",
        "    lemmatized_docs.append(lemmatized)\n",
        "\n",
        "    print(lemmatized)\n",
        "\n",
        "# -----------------------------------------\n",
        "# Step 7: Convert List to Sentence\n",
        "# -----------------------------------------\n",
        "\n",
        "final_documents = []\n",
        "\n",
        "for tokens in lemmatized_docs:\n",
        "\n",
        "    sentence = \" \".join(tokens)\n",
        "\n",
        "    final_documents.append(sentence)\n",
        "\n",
        "# -----------------------------------------\n",
        "# Step 8: TF-IDF Calculation\n",
        "# -----------------------------------------\n",
        "\n",
        "vectorizer = TfidfVectorizer()\n",
        "\n",
        "tfidf_matrix = vectorizer.fit_transform(final_documents)\n",
        "\n",
        "# Convert to DataFrame\n",
        "tfidf_df = pd.DataFrame(\n",
        "    tfidf_matrix.toarray(),\n",
        "    columns=vectorizer.get_feature_names_out()\n",
        ")\n",
        "\n",
        "print(\"\\nTF-IDF Matrix:\\n\")\n",
        "\n",
        "print(tfidf_df)\n",
        "\n",
        "# -----------------------------------------\n",
        "# Step 9: Save TF-IDF Output\n",
        "# -----------------------------------------\n",
        "\n",
        "tfidf_df.to_csv(\"TFIDF_Output.csv\", index=False)\n",
        "\n",
        "print(\"\\nTF-IDF Output Saved Successfully!\")"
      ],
