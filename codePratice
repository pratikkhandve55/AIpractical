        "# Practical 2: Academic Performance Dataset Preprocessing\n",
        "\n",
        "\n",
        "# Import Libraries\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "\n",
        "\n",
        "data = {\n",
        "    'Student_ID': [101,102,103,104,105,106,107,108,109,110],\n",
        "\n",
        "    # Inconsistent Names\n",
        "    'Name': ['Rahul','PRIYA','Amit','Sneha ','rahul',\n",
        "             'Neha','ROHAN','Kiran',np.nan,'Pooja'],\n",
        "\n",
        "    # Missing and Inconsistent Gender Values\n",
        "    'Gender': ['Male','female','M','Female',np.nan,\n",
        "               'FEMALE','male','M','Female','f'],\n",
        "\n",
        "    # Noisy Age Data with Missing Value and Outlier\n",
        "    'Age': [20,21,np.nan,22,19,150,20,21,22,18],\n",
        "\n",
        "    # Marks with Missing Value and Outlier\n",
        "    'Maths': [85,90,78,np.nan,95,500,88,76,84,91],\n",
        "\n",
        "    'Science': [80,85,75,89,np.nan,450,90,70,82,88],\n",
        "\n",
        "    # Inconsistent City Names\n",
        "    'City': ['Pune','mumbai','Mumbai','PUNE','Delhi',\n",
        "             'delhi','Pune ','MUMBAI',np.nan,'Delhi']\n",
        "}\n",
        "\n",
        "# Create DataFrame\n",
        "df = pd.DataFrame(data)\n",
        "\n",
        "print(\"Original Noisy and Inconsistent Dataset:\\n\")\n",
        "print(df)\n",
        "\n",
        "# Step 2: Check Missing Values\n",
        "\n",
        "print(\"\\nMissing Values in Dataset:\\n\")\n",
        "print(df.isnull().sum())\n",
        "\n",
        "# Step 3: Handle Missing Values\n",
        "\n",
        "# Fill missing Name with \"Unknown\"\n",
        "df['Name'].fillna(\"Unknown\", inplace=True)\n",
        "\n",
        "# Fill missing Gender with Mode\n",
        "df['Gender'].fillna(df['Gender'].mode()[0], inplace=True)\n",
        "\n",
        "# Fill missing Age with Mean\n",
        "df['Age'].fillna(df['Age'].mean(), inplace=True)\n",
        "\n",
        "# Fill missing Maths Marks with Mean\n",
        "df['Maths'].fillna(df['Maths'].mean(), inplace=True)\n",
        "\n",
        "# Fill missing Science Marks with Mean\n",
        "df['Science'].fillna(df['Science'].mean(), inplace=True)\n",
        "\n",
        "# Fill missing City with Mode\n",
        "df['City'].fillna(df['City'].mode()[0], inplace=True)\n",
        "\n",
        "print(\"\\nDataset After Handling Missing Values:\\n\")\n",
        "print(df)\n",
        "\n",
        "# -------------------------------\n",
        "# Step 4: Data Cleaning\n",
        "# -------------------------------\n",
        "\n",
        "# Standardize Name Column\n",
        "df['Name'] = df['Name'].str.strip().str.title()\n",
        "\n",
        "# Standardize Gender Column\n",
        "df['Gender'] = df['Gender'].replace({\n",
        "    'M':'Male',\n",
        "    'male':'Male',\n",
        "    'f':'Female',\n",
        "    'female':'Female',\n",
        "    'FEMALE':'Female'\n",
        "})\n",
        "\n",
        "# Standardize City Column\n",
        "df['City'] = df['City'].str.strip().str.title()\n",
        "\n",
        "print(\"\\nDataset After Cleaning Inconsistencies:\\n\")\n",
        "print(df)\n",
        "\n",
        "# -------------------------------\n",
        "# Step 5: Detect Outliers\n",
        "# -------------------------------\n",
        "\n",
        "print(\"\\nOutlier Detection:\\n\")\n",
        "\n",
        "# Using IQR Method for Maths Marks\n",
        "Q1 = df['Maths'].quantile(0.25)\n",
        "Q3 = df['Maths'].quantile(0.75)\n",
        "\n",
        "IQR = Q3 - Q1\n",
        "\n",
        "lower_limit = Q1 - 1.5 * IQR\n",
        "upper_limit = Q3 + 1.5 * IQR\n",
        "\n",
        "outliers = df[(df['Maths'] < lower_limit) | (df['Maths'] > upper_limit)]\n",
        "\n",
        "print(\"Outliers in Maths Marks:\\n\")\n",
        "print(outliers)\n",
        "\n",
        "# -------------------------------\n",
        "# Step 6: Remove Outliers\n",
        "# -------------------------------\n",
        "\n",
        "df = df[(df['Maths'] >= lower_limit) & (df['Maths'] <= upper_limit)]\n",
        "\n",
        "print(\"\\nDataset After Removing Outliers:\\n\")\n",
        "print(df)\n",
        "\n",
        "# -------------------------------\n",
        "# Step 7: Data Transformation\n",
        "# -------------------------------\n",
        "\n",
        "# Convert Age into Integer\n",
        "df['Age'] = df['Age'].astype(int)\n",
        "\n",
        "# Create Average Marks Column\n",
        "df['Average_Marks'] = (df['Maths'] + df['Science']) / 2\n",
        "\n",
        "# Create Performance Category\n",
        "df['Performance'] = np.where(df['Average_Marks'] >= 85,\n",
        "                             'Excellent',\n",
        "                             'Average')\n",
        "\n",
        "print(\"\\nDataset After Transformation:\\n\")\n",
        "print(df)\n",
        "\n",
        "# -------------------------------\n",
        "# Step 8: Statistical Summary\n",
        "# -------------------------------\n",
        "\n",
        "print(\"\\nStatistical Summary:\\n\")\n",
        "print(df.describe())\n",
        "\n",
        "# -------------------------------\n",
        "# Step 9: Save Cleaned Dataset\n",
        "# -------------------------------\n",
        "\n",
        "df.to_csv(\"Cleaned_Academic_Performance.csv\", index=False)\n",
        "\n",
        "print(\"\\nCleaned Dataset Saved Successfully!\")"
